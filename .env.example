# --- GCP ---
GCP_PROJECT_ID=governed-agentic-analytics
GCP_REGION=australia-southeast1
GCP_LOCATION=australia-southeast1

# --- BigQuery datasets ---
BQ_DATASET_RAW=raw
BQ_DATASET_STAGING=staging
BQ_DATASET_MARTS=marts

# --- GCS buckets ---
GCS_RAW_BUCKET=governed-agentic-analytics-raw
GCS_ARTIFACTS_BUCKET=governed-agentic-analytics-artifacts

# --- OpenAI (LLM for NL->SQL, enrichment, summarisation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- Langfuse (LLM tracing/observability) ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- AWS (S3 cross-cloud file connector; added in Phase 2) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-southeast-2
S3_SOURCE_BUCKET=
